{
  "manifest_version": 3,
  "name": "YT Shield – Ad Blocker & Auto-Refresh",
  "author": "Saurabh Sugandh (SudoDocs)",
  "version": "1.0.0",
  "description": "Blocks YouTube ads, removes end cards & overlays, and auto-refreshes when video errors occur. Works on Chrome and Brave.",
  "permissions": ["tabs", "scripting", "storage", "declarativeNetRequest"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.googlevideo.com/*",
    "*://*.doubleclick.net/*",
    "*://*.googleadservices.com/*",
    "*://*.google-analytics.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ad_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
